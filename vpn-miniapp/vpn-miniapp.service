[Unit]
Description=VPN Mini App — FastAPI Backend
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/vpn-miniapp
EnvironmentFile=/root/vpn-miniapp/.env
ExecStart=/usr/bin/python3 -m uvicorn main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 1 \
    --log-level info
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vpn-miniapp

[Install]
WantedBy=multi-user.target
